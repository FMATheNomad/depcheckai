{
  "name": "@fmathenomad/depcheckai",
  "version": "0.1.0",
  "description": "One command — audit your dependencies for deprecated, risky & outdated packages across npm, PyPI & crates.io. Like npm audit meets AI-powered recommendations.",
  "keywords": [
    "depcheck",
    "npm",
    "dependencies",
    "dependency-check",
    "nodejs",
    "javascript",
    "cli",
    "developer-tools",
    "code-quality",
    "unused-packages",
    "missing-packages",
    "outdated-packages",
    "open-source",
    "solo-founder",
    "package-audit",
    "dependency-management",
    "depcheckai",
    "npm-audit",
    "pypi",
    "crates-io"
  ],
  "homepage": "https://github.com/FMATheNomad/depcheckai#readme",
  "bugs": {
    "url": "https://github.com/FMATheNomad/depcheckai/issues"
  },
  "type": "module",
  "license": "MIT",
  "author": "FMATheNomad",
  "bin": {
    "depcheckai": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "src/github-action/action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "chalk": "^5.6.2",
    "ora": "^9.4.1",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.13.2",
    "@types/semver": "^7.7.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FMATheNomad/depcheckai.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
