{
  "name": "depcheck-ai",
  "version": "0.1.0",
  "description": "AI that reads your dependencies — tells you what's broken, deprecated, or risky",
  "keywords": [
    "dependency-checker",
    "npm-audit",
    "health-score",
    "cli",
    "developer-tools",
    "package-registry",
    "supply-chain-security"
  ],
  "homepage": "https://github.com/FMATheNomad/depcheck-ai#readme",
  "bugs": {
    "url": "https://github.com/FMATheNomad/depcheck-ai/issues"
  },
  "type": "module",
  "license": "MIT",
  "author": "FMATheNomad",
  "bin": {
    "depcheck-ai": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "src/github-action/action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/semver": "^7.5.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FMATheNomad/depcheck-ai.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
